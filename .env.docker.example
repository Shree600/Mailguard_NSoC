# ================================================
# MAILGUARD - DOCKER COMPOSE ENVIRONMENT VARIABLES
# ================================================
# Copy this file to .env in the root directory:
#   cp .env.docker.example .env
#
# Then fill in all the values before running:
#   docker compose up --build
# ================================================

# ================================================
# MONGODB CONFIGURATION
# ================================================
# CRITICAL: Change these in production!
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change_this_to_secure_password

# MongoDB connection string (update password to match above)
MONGO_URI=mongodb://admin:change_this_to_secure_password@mongo:27017/mailguard?authSource=admin

# ================================================
# CLERK AUTHENTICATION
# ================================================
# Get these from: https://dashboard.clerk.com
# Backend secret key (starts with sk_test_ or sk_live_)
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Frontend publishable key (starts with pk_test_ or pk_live_)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# ================================================
# GMAIL OAUTH CONFIGURATION
# ================================================
# Get these from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Production: Use your domain, e.g., https://yourdomain.com/api/gmail/callback
# Development: Use http://localhost:5000/api/gmail/callback
GOOGLE_REDIRECT_URI=http://localhost:5000/api/gmail/callback

# ================================================
# ENCRYPTION CONFIGURATION
# ================================================
# CRITICAL: Generate a secure 32-byte hex key for encrypting Gmail tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER commit this to git! Keep it secret!
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# ================================================
# FRONTEND CONFIGURATION
# ================================================
# API base URL (used by frontend to connect to backend)
# Production: Use your backend domain, e.g., https://api.yourdomain.com/api
# Development: Use http://localhost:5000/api
VITE_API_BASE_URL=http://localhost:5000/api

# Frontend URL (used by backend for CORS)
# Production: Use your frontend domain, e.g., https://yourdomain.com
# Development: Use http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ================================================
# ML SERVICE CONFIGURATION
# ================================================
# Internal Docker network URL (no need to change)
ML_SERVICE_URL=http://ml-service:8000

# ================================================
# OPTIONAL: SCHEDULER CONFIGURATION
# ================================================
# Cron schedule for automatic model retraining (default: 2 AM daily)
RETRAIN_SCHEDULE=0 2 * * *

# Cron schedule for email scanning job (default: 2 AM daily)
SCAN_SCHEDULE=0 2 * * *

# ================================================
# DEPLOYMENT NOTES
# ================================================
# 1. Copy this file to .env: cp .env.docker.example .env
# 2. Generate ENCRYPTION_KEY: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 3. Set all credentials from Clerk and Google Cloud Console
# 4. Update MONGO_ROOT_PASSWORD to a strong password
# 5. Update MONGO_URI with the same password
# 6. In production, use HTTPS URLs for all external endpoints
# 7. Run: docker compose up --build
# ================================================
