# ================================================
# CLERK AUTHENTICATION CONFIGURATION
# ================================================
# Get these keys from: https://dashboard.clerk.com
# IMPORTANT: If your keys were exposed, regenerate them immediately!
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# ================================================
# DATABASE CONFIGURATION
# ================================================
# Local development (no auth):
# MONGO_URI=mongodb://localhost:27017/mailguard

# Docker deployment (with auth):
MONGO_URI=mongodb://admin:your_password@mongo:27017/mailguard?authSource=admin

# Production (MongoDB Atlas or secured instance):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/mailguard?retryWrites=true&w=majority

# ================================================
# GMAIL OAUTH CONFIGURATION
# ================================================
# Get these from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=84702114664-tunt8hqgiisl9mi78kbbk36e2f8s1emq.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URI=http://localhost:5000/api/gmail/callback

# ================================================
# ENCRYPTION CONFIGURATION
# ================================================
# 32-byte hex key for encrypting sensitive data (Gmail tokens)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: Keep this secret and never commit to git!
ENCRYPTION_KEY=your_64_character_hex_key_here

# ================================================
# ML SERVICE CONFIGURATION
# ================================================
ML_SERVICE_URL=http://ml-service:8000

# ================================================
# SERVER CONFIGURATION
# ================================================
PORT=5000
NODE_ENV=development

# Frontend URL for CORS (restrict API access to your frontend only)
FRONTEND_URL=http://localhost:3000

# ================================================
# OPTIONAL: SCHEDULER CONFIGURATION
# ================================================
# Cron schedule for automatic model retraining (default: 0 2 * * * - 2 AM daily)
RETRAIN_SCHEDULE=0 2 * * *
# Cron schedule for email scanning job (default: 0 2 * * * - 2 AM daily)
SCAN_SCHEDULE=0 2 * * *
