# ================================================
# MAILGUARD - ENVIRONMENT CONFIGURATION
# ================================================
# Copy this file to .env and update with your values
# DO NOT commit .env to version control
#
# DOCKER USAGE (recommended):
# - Default values are configured for Docker Compose
# - Service names (mongo, ml-service, backend) resolve via Docker network
# - No changes needed if using: docker compose up
#
# LOCAL DEVELOPMENT (without Docker):
# - Change mongo -> 127.0.0.1
# - Change ml-service -> localhost
# - Change backend -> localhost

# ================================================
# SERVER CONFIGURATION
# ================================================
# Port for Node.js backend server
PORT=5000

# ================================================
# DATABASE CONFIGURATION
# ================================================
# MongoDB connection string
# Docker:  mongodb://mongo:27017/mailguard (recommended)
# Local:   mongodb://127.0.0.1:27017/mailguard
# Cloud:   mongodb+srv://<username>:<password>@<cluster>.mongodb.net/mailguard
MONGO_URI=mongodb://mongo:27017/mailguard

# ================================================
# JWT AUTHENTICATION
# ================================================
# Secret key for signing JWT tokens
# IMPORTANT: Change this to a strong random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# ================================================
# GOOGLE OAUTH 2.0 CONFIGURATION
# ================================================
# Get credentials from: https://console.cloud.google.com/
# 1. Create a project
# 2. Enable Gmail API
# 3. Create OAuth 2.0 credentials
# 4. Add authorized redirect URI

# Google OAuth Client ID
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Google OAuth Client Secret
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# OAuth Redirect URI (must match Google Console configuration)
# Docker:  http://localhost:5000/api/gmail/callback (use host machine IP)
# Local:   http://localhost:5000/api/gmail/callback
# Production: https://yourdomain.com/api/gmail/callback
GOOGLE_REDIRECT_URI=http://localhost:5000/api/gmail/callback

# ================================================
# ML SERVICE CONFIGURATION
# ================================================
# URL of the ML prediction service (FastAPI)
# Docker:  http://ml-service:8000 (recommended)
# Local:   http://localhost:8000
ML_SERVICE_URL=http://ml-service:8000

# ================================================
# BACKEND SERVICE CONFIGURATION
# ================================================
# URL of the backend API (for scheduled jobs)
# Used by retraining scheduler to call admin endpoints
# Docker:  http://backend:5000 (recommended)
# Local:   http://localhost:5000
BACKEND_URL=http://backend:5000

# ================================================
# SCHEDULED JOBS CONFIGURATION
# ================================================
# Cron schedule for automatic model retraining
# Format: minute hour day month weekday
# Examples:
#   - "0 2 * * *"     = Every day at 2:00 AM
#   - "0 */6 * * *"   = Every 6 hours
#   - "*/5 * * * *"   = Every 5 minutes (testing)
RETRAIN_SCHEDULE=0 2 * * *

# ================================================
# OPTIONAL: ADDITIONAL CONFIGURATION
# ================================================

# Node Environment (development/production)
# NODE_ENV=development

# Frontend URL (for CORS in production)
# FRONTEND_URL=http://localhost:5173

# Log Level (error/warn/info/debug)
# LOG_LEVEL=info
